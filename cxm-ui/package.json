{
  "name": "cxm-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared CXM frontend widget library (contract-bound): typed API contract + widgets over cxm-server. Layer 2 of agdelte → cxm-ui → sites.",
  "scripts": {
    "build:contract": "agda --js --js-es6 --js-optimize --compile-dir=_build CxmUI/Contract.agda",
    "build:client": "agda --js --js-es6 --js-optimize --compile-dir=_build CxmUI/Client.agda",
    "build:card": "agda --js --js-es6 --js-optimize --compile-dir=_build CxmUI/ClientCard.agda",
    "build:feed": "agda --js --js-es6 --js-optimize --compile-dir=_build CxmUI/Feed.agda",
    "build:thread": "agda --js --js-es6 --js-optimize --compile-dir=_build CxmUI/Thread.agda",
    "build:showcase": "agda --js --js-es6 --js-optimize --compile-dir=_build CxmUI/Showcase.agda",
    "build:widgets": "npm run build:card && npm run build:feed && npm run build:thread && npm run build:showcase",
    "test:contract": "node test/contract.test.mjs",
    "test:client": "node test/client.test.mjs",
    "test": "npm run build:client && npm run test:contract && npm run test:client",
    "dev": "npm run build:widgets && node dev/serve.mjs",
    "test:smoke": "npm run build:widgets && node dev/smoke.mjs"
  }
}
